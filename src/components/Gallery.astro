---
import { galleryItems } from "../data/gallery";
const featuredGalleryItems = galleryItems.filter((item) => item.featured);

---

<section id="gallery" class="bg-white px-6 py-16 md:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-rose-700">
          Gallery
        </p>

        <h2 class="font-serif text-3xl font-bold tracking-tight text-stone-950 md:text-4xl">
          A few recent bakes
        </h2>

        <p class="mt-4 text-base leading-7 text-stone-700">
          Swipe through a few custom cakes and treats made for recent celebrations.
        </p>
      </div>

      <a
        href="/gallery"
        class="text-sm font-semibold text-rose-700 hover:text-rose-800"
      >
        View full gallery →
      </a>
    </div>

    <div class="mt-10 flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory">
  {featuredGalleryItems.map((item) => (
    <div class="flex-none w-[82%] snap-center overflow-hidden rounded-3xl bg-rose-50 p-3 shadow-sm ring-1 ring-rose-100 sm:w-[45%] lg:w-[30%]">
      <div class="aspect-square overflow-hidden rounded-2xl">
        <img
          src={item.src}
          alt={item.alt}
          class="h-full w-full object-cover object-center"
        />
      </div>
    </div>
  ))}
</div>
  </div>
</section>