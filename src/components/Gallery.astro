---
const galleryItems = [
  "Birthday cake",
  "Cupcakes",
  "Custom cake",
  "Dessert box",
  "Celebration cake",
  "Holiday treats",
];
---

<section id="gallery" class="bg-white px-6 py-16 md:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-rose-700">
        Gallery
      </p>

      <h2 class="font-serif text-3xl font-bold tracking-tight text-stone-950 md:text-4xl">
        Recent bakes and sweet creations
      </h2>

      <p class="mt-4 text-base leading-7 text-stone-700">
        A look at custom cakes, cupcakes, and treats made for birthdays,
        holidays, and special occasions.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {galleryItems.map((item) => (
        <div class="overflow-hidden rounded-3xl bg-amber-50 p-3 shadow-sm ring-1 ring-rose-100">
          <div class="flex aspect-square items-center justify-center rounded-2xl bg-rose-50 text-sm font-medium text-stone-500">
            {item} photo
          </div>
        </div>
      ))}
    </div>
  </div>
</section>