---
import { galleryItems } from "../data/gallery";

const heroImage = galleryItems.find((item) => item.hero);
---
<section class="px-6 py-16 md:py-24">
  <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-2 md:items-center">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-rose-700">
        Custom cakes & sweet treats
      </p>

      <h1 class="font-serif text-4xl font-bold tracking-tight text-stone-950 md:text-6xl">
        Whisk Bake Repeat
      </h1>

      <p class="mt-6 max-w-xl text-base leading-7 text-stone-700 md:text-lg md:leading-8">
        Homemade cakes, cupcakes, and desserts made with care for birthdays,
        celebrations, and life’s sweetest moments.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/gallery"
          class="rounded-full bg-stone-950 px-6 py-3 text-center text-sm font-semibold text-white shadow-sm hover:bg-stone-800"
        >
          View Gallery
        </a>

        <a
          href="#contact"
          class="rounded-full border border-stone-300 bg-white px-6 py-3 text-center text-sm font-semibold text-stone-900 shadow-sm hover:border-rose-300 hover:text-rose-700"
        >
          Contact to Order
        </a>
      </div>
    </div>
    {heroImage && (
  <div class="rounded-[2rem] bg-white p-4 shadow-sm ring-1 ring-rose-100">
    <img
      src={heroImage.src}
      alt={heroImage.alt}
      class="aspect-[4/5] w-full rounded-[1.5rem] object-cover"
    />
  </div>
)}
  </div>
</section>