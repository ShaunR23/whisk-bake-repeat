
---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { galleryItems } from "../data/gallery";

const gallerySections = [
  {
    title: "Cakes",
    description: "Custom cakes for birthdays, celebrations, and special moments.",
    items: galleryItems.filter((item) => item.category === "Cakes"),
  },
  {
    title: "Mini Loaves",
    description: "Sweet mini loaves for gifting, gatherings, and everyday treats.",
    items: galleryItems.filter((item) => item.category === "miniLoaves"),
  },
  {
    title: "Cupcakes & More",
    description: "Cupcakes, dessert boxes, seasonal treats, and other sweet creations.",
    items: galleryItems.filter((item) => item.category === "cupcakesAndMore"),
  },
];
---

<Layout
  title="Gallery | Whisk Bake Repeat"
  description="Browse custom cakes, cupcakes, and sweet treats from Whisk Bake Repeat."
>
  <Header />

  <main class="bg-amber-50 px-6 py-16 md:py-24">
    <section class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-rose-700">
          Gallery
        </p>

        <h1 class="font-serif text-4xl font-bold tracking-tight text-rose-900 md:text-6xl">
          Sweet creations for every celebration
        </h1>

        <p class="mt-5 text-base leading-7 text-stone-700 md:text-lg">
          Browse recent cakes, cupcakes, and custom treats from Whisk Bake Repeat.
        </p>
      </div>

      <div class="mt-12 space-y-16">
  {gallerySections.map((section) => (
    section.items.length > 0 && (
      <section>
        <div class="max-w-2xl">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-rose-900 md:text-4xl">
            {section.title}
          </h2>

          <p class="mt-3 text-base leading-7 text-stone-700">
            {section.description}
          </p>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-3">
  {section.items.map((item) => (
    <button
      type="button"
      class="group cursor-pointer overflow-hidden rounded-2xl bg-rose-50 p-2 shadow-sm ring-1 ring-rose-100 transition hover:-translate-y-0.5 hover:shadow-md sm:rounded-3xl sm:p-3"
      data-lightbox-src={item.src}
      data-lightbox-alt={item.alt}
    >
      <img
        src={item.src}
        alt={item.alt}
        class="aspect-square w-full rounded-xl object-cover object-center transition group-hover:scale-[1.02] sm:rounded-2xl"
      />
    </button>
  ))}
</div>
      </section>
    )
  ))}
</div>

      <div class="mt-16 rounded-[2rem] bg-rose-900 px-6 py-10 text-center text-white shadow-sm md:px-12">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-rose-200">
          Like what you see?
        </p>

        <h2 class="mt-3 font-serif text-3xl font-bold tracking-tight md:text-4xl">
          Ask about availability for your next celebration
        </h2>

        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-rose-100">
          Reach out with your event date, dessert idea, serving size, and any
          inspiration photos. We’ll follow up with availability and next steps.
        </p>

        <a
          href="/#contact"
          class="mt-8 inline-flex rounded-full bg-white px-6 py-3 text-sm font-semibold text-rose-900 shadow-sm hover:bg-amber-50"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 px-4 py-8"
>
  <button
    type="button"
    id="lightbox-close"
    class="absolute right-4 top-4 rounded-full bg-white px-4 py-2 text-sm font-semibold text-stone-950 shadow-sm"
  >
    Close
  </button>

  <button
    type="button"
    id="lightbox-prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 rounded-full bg-white/90 px-4 py-3 text-2xl font-bold text-stone-950 shadow-sm hover:bg-white"
    aria-label="Previous image"
  >
    ‹
  </button>

  <img
    id="lightbox-image"
    src=""
    alt=""
    class="max-h-[85vh] min-w-[70vw] max-w-[92vw] rounded-2xl object-contain shadow-2xl md:min-w-[40vw]"
  />

  <button
    type="button"
    id="lightbox-next"
    class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full bg-white/90 px-4 py-3 text-2xl font-bold text-stone-950 shadow-sm hover:bg-white"
    aria-label="Next image"
  >
    ›
  </button>
</div>

<script>
  const lightbox = document.querySelector("#lightbox");
  const lightboxImage = document.querySelector("#lightbox-image");
  const closeButton = document.querySelector("#lightbox-close");
  const prevButton = document.querySelector("#lightbox-prev");
  const nextButton = document.querySelector("#lightbox-next");
  const imageButtons = Array.from(
    document.querySelectorAll("[data-lightbox-src]")
  );

  let currentImageIndex = 0;

  function showImage(index) {
    const button = imageButtons[index];

    if (!button || !lightboxImage) return;

    const src = button.getAttribute("data-lightbox-src");
    const alt = button.getAttribute("data-lightbox-alt") ?? "";

    if (!src) return;

    lightboxImage.setAttribute("src", src);
    lightboxImage.setAttribute("alt", alt);
    currentImageIndex = index;
  }

  function openLightbox(index) {
    if (!lightbox) return;

    showImage(index);

    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    if (!lightbox || !lightboxImage) return;

    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    lightboxImage.setAttribute("src", "");
    lightboxImage.setAttribute("alt", "");
    document.body.style.overflow = "";
  }

  function showPreviousImage() {
    const previousIndex =
      currentImageIndex === 0 ? imageButtons.length - 1 : currentImageIndex - 1;

    showImage(previousIndex);
  }

  function showNextImage() {
    const nextIndex =
      currentImageIndex === imageButtons.length - 1 ? 0 : currentImageIndex + 1;

    showImage(nextIndex);
  }

  imageButtons.forEach((button, index) => {
    button.addEventListener("click", () => {
      openLightbox(index);
    });
  });

  closeButton?.addEventListener("click", closeLightbox);
  prevButton?.addEventListener("click", showPreviousImage);
  nextButton?.addEventListener("click", showNextImage);

  lightbox?.addEventListener("click", (event) => {
    if (event.target === lightbox) {
      closeLightbox();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (!lightbox || lightbox.classList.contains("hidden")) return;

    if (event.key === "Escape") {
      closeLightbox();
    }

    if (event.key === "ArrowLeft") {
      showPreviousImage();
    }

    if (event.key === "ArrowRight") {
      showNextImage();
    }
  });
</script>
</Layout>